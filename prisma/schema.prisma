datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum LinkPrecedence {
  primary
  secondary
}

model Contact {
  id             Int             @id @default(autoincrement())
  phoneNumber    String?
  email          String?
  linkedId       Int?
  linkPrecedence LinkPrecedence  @default(primary)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  // Relations
  linkedContact Contact?  @relation("ContactLink", fields: [linkedId], references: [id])
  linkedFrom    Contact[] @relation("ContactLink")

  @@index([email])
  @@index([phoneNumber])
}
